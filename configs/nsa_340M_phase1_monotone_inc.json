    "hidden_size": 1024,
    "initializer_range": 0.006,
    "max_position_embeddings": 8192,
    "model_type": "nsa",
    "num_heads": 32,
    "num_kv_heads": 2,
    "head_dim": 64,
    "block_size": 64,
    "block_counts": [8, 8, 8, 8, 8, 8, 12, 12, 12, 12, 12, 12, 20, 20, 20, 20, 20, 20, 24, 24, 24, 24, 24, 24],
    "window_size": 512,
    "num_hidden_layers": 24,
    "norm_eps": 1e-06,
    "tie_word_embeddings": false,
    "use_cache": true,
    "vocab_size": 32000,
    "budget_mode": "layer_aware",
